{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfigPath": "/nixpacks.toml"
  },
  "deploy": {
    "startCommand": "mkdir -p uploads && node server.js",
    "healthcheckPath": "/api/team",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
